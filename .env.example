# Brain OS — Environment Configuration
# Copy to .env and fill in your values

# Server port
PORT=3333

# AI Model to use (default: gpt-5-mini)
BRAIN_MODEL=gpt-5-mini

# Copilot API endpoint (run: npx copilot-api@latest start)
COPILOT_API_URL=http://localhost:4141

# ── Agent API Keys (only needed for non-Copilot agents) ──
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# ── Web Search ────────────────────────────────────────────
# Brave Search API key (free tier: 2,000 queries/month)
# Get at: https://api.search.brave.com/
# If not set, falls back to DuckDuckGo HTML scraping
BRAVE_API_KEY=

# ── Telegram ──────────────────────────────────────────────
# Token is set via /api/telegram/connect — not loaded directly by runtime
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# ── OpenRouter ────────────────────────────────────────────
OPENROUTER_REFERER=http://localhost:3333

# ── Supabase (required) ───────────────────────────────────
# Get from: supabase.com > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

TAVILY_API_KEY=