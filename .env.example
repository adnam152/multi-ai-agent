# Brain OS — Environment Configuration
# Copy to .env and fill in your values

# Server port
PORT=3333

# AI Model to use (default: gpt-5-mini)
BRAIN_MODEL=gpt-5-mini

# Copilot API endpoint (run: npx copilot-api@latest start)
COPILOT_API_URL=http://localhost:4141

# Telegram keys (currently not loaded directly by runtime; Telegram token is set via /api/telegram/connect)
TELEGRAM_BOT_TOKEN=

# Telegram Owner Chat ID (reserved)
TELEGRAM_OWNER_CHAT_ID=

# OpenRouter referer override (optional)
OPENROUTER_REFERER=http://localhost:3333

# Supabase (get from: supabase.com > Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
